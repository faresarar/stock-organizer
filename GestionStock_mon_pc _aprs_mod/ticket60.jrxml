	<queryString>
		<![CDATA[SELECT
distinct
     vente_data.`id` AS vente_data_id,
     vente_data.`numero_facture` AS vente_data_numero_facture,
     vente_data.`barecode` AS vente_data_barecode,
     vente_data.`total` AS vente_data_total,
     vente_data.`remise` AS vente_data_remise,
     vente_data.`versement` AS vente_data_versement,
     vente_data.`rest` AS vente_data_rest,
     vente_data.`client` AS vente_data_client,
     vente_data.`username` AS vente_data_username,
     vente_detaille.`designation` AS vente_detaille_data_designation,
     vente_detaille.`qnt` AS vente_detaille_data_qnt,
     vente_detaille.`prix_vente` AS vente_detaille_data_prix_vente,
     infos.`nom` AS infos_nom,
     infos.`adresse` AS infos_adresse,
     infos.`tele1` AS infos_tele1,
     infos.`activite` AS infos_activite,
     infos.`logo` AS infos_logo,
     print.`message` AS print_message,
     vente_data.`date` AS vente_data_date
FROM
     `vente_data` vente_data INNER JOIN `vente_detaille` vente_detaille ON vente_data.`id` = vente_detaille.`id_vente`,
     `infos` infos, `print` print
WHERE
     vente_data.`id` = $P{id_vente} And
 print.`user_id` = $P{id_user} and infos.`id` = 1]]>
	</queryString>
